rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }

    function adminUidFromUsername() {
      return exists(/databases/$(database)/documents/usernames/admin)
        ? get(/databases/$(database)/documents/usernames/admin).data.uid
        : '';
    }

    function storedUserRole(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        ? get(/databases/$(database)/documents/users/$(uid)).data.role
        : '';
    }

    function hasStoredUserRole(uid) {
      return storedUserRole(uid) == 'admin' || storedUserRole(uid) == 'user';
    }

    function bootstrapAdmin() {
      return signedIn()
        && request.auth.uid == adminUidFromUsername()
        && !hasStoredUserRole(request.auth.uid);
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true
        || storedUserRole(request.auth.uid) == 'admin'
        || bootstrapAdmin()
      );
    }

    function validRequestedUserRole() {
      return !request.resource.data.keys().hasAny(['role'])
        || request.resource.data.role == 'user'
        || request.resource.data.role == 'admin';
    }

    function selfCanWriteOwnUserDoc(uid) {
      return signedIn()
        && request.auth.uid == uid
        && validRequestedUserRole()
        && (
          !request.resource.data.keys().hasAny(['role'])
          || (
            hasStoredUserRole(uid)
            && request.resource.data.role == storedUserRole(uid)
          )
        );
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if username.matches('^[a-z0-9_]{3,20}$')
        && (
          isAdmin() || (
            signedIn()
            && !exists(/databases/$(database)/documents/usernames/$(username))
            && (
              (
                request.resource.data.uid == request.auth.uid
                && request.resource.data.authHandle is string
                && request.resource.data.authHandle != ''
              ) || (
                request.resource.data.uid == ''
                && request.resource.data.authHandle is string
                && request.resource.data.authHandle == ''
                && request.resource.data.invitedByUid == request.auth.uid
              )
            )
          )
        );
      allow update: if username.matches('^[a-z0-9_]{3,20}$')
        && (
          isAdmin() || (
            signedIn()
            && (
              (
                resource.data.uid == ''
                && request.resource.data.uid == request.auth.uid
                && request.resource.data.authHandle is string
                && request.resource.data.authHandle != ''
              ) || (
                resource.data.uid == request.auth.uid
                && request.resource.data.uid == resource.data.uid
                && request.resource.data.authHandle == resource.data.authHandle
              )
            )
          )
        );
      allow delete: if isAdmin() || (signedIn() && request.auth.uid == resource.data.uid);
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if (isAdmin() && validRequestedUserRole()) || selfCanWriteOwnUserDoc(uid);
      allow update: if (isAdmin() && validRequestedUserRole()) || selfCanWriteOwnUserDoc(uid);
      allow delete: if isAdmin() || (signedIn() && request.auth.uid == uid);
    }

    match /debates/{debateId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.debaterAUid is string
        && request.resource.data.debaterBUid is string
        && request.resource.data.debaterAUid != request.resource.data.debaterBUid
        && request.resource.data.topic is string
        && request.resource.data.category is string
        && (
          request.resource.data.category == 'philosophy'
          || request.resource.data.category == 'politics'
          || request.resource.data.category == 'misc'
        )
        && (
          (
            request.resource.data.status == 'scheduled'
            && request.resource.data.result == 'pending'
          ) || (
            isAdmin()
            && request.resource.data.status == 'resolved'
            && (
              request.resource.data.result == 'a'
              || request.resource.data.result == 'b'
              || request.resource.data.result == 'draw'
            )
            && request.resource.data.claimedByUid == request.auth.uid
          )
        );
      allow update: if isAdmin();
      allow delete: if isAdmin() || (signedIn()
        && resource.data.createdByUid == request.auth.uid
        && resource.data.status == 'scheduled');
    }
  }
}
